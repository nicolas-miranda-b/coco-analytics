# Copiar a .env y completar. En desarrollo se puede dejar todo por defecto:
# sin token de WhatsApp, los envíos se simulan y quedan en el log.

# Base de datos (SQLite por defecto; en producción usar PostgreSQL)
TATARECETA_DB=sqlite:///./tatareceta.db
# TATARECETA_DB=postgresql+psycopg://usuario:clave@localhost:5432/tatareceta

# WhatsApp Cloud API (Meta)
WHATSAPP_TOKEN=
WHATSAPP_NUMERO_ID=
WEBHOOK_VERIFY_TOKEN=tatareceta-dev

# Negocio
CONSULTAS_GRATIS=3
PRECIO_SUSCRIPCION_BS=7

# URL pública de esta API (para el link de la imagen del QR en WhatsApp)
BASE_URL_PUBLICA=http://localhost:8000

# Pagos por QR: "simulado" (desarrollo) o "bnb" (Banco Nacional de Bolivia)
PAGOS_PROVEEDOR=simulado
# Secreto opcional que el banco manda en el header X-Webhook-Secret
PAGOS_WEBHOOK_SECRET=
# Credenciales del Mercado de APIs del BNB (https://marketapi.bnb.com.bo;
# pruebas: http://test.bnb.com.bo). Se solicitan al banco.
BNB_URL_BASE=https://marketapi.bnb.com.bo
BNB_ACCOUNT_ID=
BNB_AUTHORIZATION_ID=

# OCR de recetas: "auto" | "claude" | "simulado"
# auto = usa Claude si hay ANTHROPIC_API_KEY; si no, simulado si hay texto; si no, deshabilitado
OCR_PROVEEDOR=auto
ANTHROPIC_API_KEY=
# Modelo para leer recetas: claude-opus-4-8 (mejor visión, ~Bs 0.10-0.20/receta)
# Alternativas si el costo por consulta pesa: claude-sonnet-5, claude-haiku-4-5
OCR_MODELO=claude-opus-4-8
OCR_SIMULADO_TEXTO=

# Panel administrativo
ADMIN_TOKEN=cambia-este-token
